---
// Selbst-gehostete Fonts (kein Google Fonts) — wird lokal aus dist/_astro
// ausgeliefert. Entspricht dem Datenschutz-Hinweis „Schriftarten lokal
// eingebunden, keine Verbindung zu Google".
import '@fontsource/bebas-neue/400.css';
import '@fontsource/pt-sans/400.css';
import '@fontsource/pt-sans/700.css';
import '@fontsource/pt-sans/400-italic.css';
// Kritische Schriftdateien vorab laden, damit sie beim ersten Rendern schon da
// sind (verhindert das sichtbare Nachladen/„Ruckeln" der Schrift).
import bebas400 from '@fontsource/bebas-neue/files/bebas-neue-latin-400-normal.woff2?url';
import ptsans400 from '@fontsource/pt-sans/files/pt-sans-latin-400-normal.woff2?url';
import ptsans700 from '@fontsource/pt-sans/files/pt-sans-latin-700-normal.woff2?url';
import '../styles/tokens.css';
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Consent from '../components/Consent.astro';
import { u } from '../lib/url';

export interface Props {
  title: string;
  description: string;
  active?: string;
  /** ungenutzt — Playfair wird direkt in den betreffenden Seiten importiert */
  playfair?: boolean;
}
const { title, description, active = '' } = Astro.props;
const fullTitle = title ? `${title} · GELD VERSTEHEN` : 'GELD VERSTEHEN';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href={u('/favicon.svg')} type="image/svg+xml" />
  <meta name="theme-color" content="#1E73BE" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="GELD VERSTEHEN" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="de_DE" />
  <meta name="twitter:card" content="summary" />

  <!-- Kritische Fonts vorladen (verhindert Font-Flackern beim Laden) -->
  <link rel="preload" as="font" type="font/woff2" href={bebas400} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={ptsans400} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={ptsans700} crossorigin />
</head>
<body>
  <SiteNav active={active} />
  <slot />
  <SiteFooter />
  <Consent />
</body>
</html>
