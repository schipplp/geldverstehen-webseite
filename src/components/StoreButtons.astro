---
// App-Store-Buttons mit den Plattform-Icons (Apple-Logo + Google-Play-Symbol).
// Verlinkt auf die OnePeek-Einträge in den Stores.
const APP_STORE = 'https://apps.apple.com/de/app/budget-app-onepeek/id1571656912';
const GOOGLE_PLAY = 'https://play.google.com/store/apps/details?id=app.onepeek&gl=DE';
---
<div class="gv-stores">
  <a class="gv-store" href={APP_STORE} target="_blank" rel="noopener" aria-label="OnePeek im App Store laden">
    <svg class="gv-store-ico" viewBox="0 0 384 512" width="20" height="20" fill="currentColor" aria-hidden="true">
      <path d="M318.7 268.7c-.2-36.7 16.4-64.4 49.5-85-18.6-26.6-46.6-41.2-83.6-44-35-2.8-73.3 20.6-87 20.6-14.5 0-48.5-20-74.7-19.5-38.5.6-74.2 22.4-94 56.9-40.1 69.5-10.3 172.4 28.9 228.9 19.1 27.6 41.9 58.6 71.8 57.5 28.8-1.1 39.7-18.6 74.5-18.6 34.6 0 44.6 18.6 74.9 18 30.9-.5 50.5-28.1 69.4-55.8 21.8-32 30.7-63 31.2-64.6-.7-.3-59.9-23-60.6-91.2zM262 116.6c15.9-19.3 26.6-46 23.7-72.6-22.9.9-50.6 15.3-67 34.5-14.7 17-27.6 44.2-24.2 70.3 25.6 2 51.7-13 67.5-32.2z"/>
    </svg>
    <span>App Store</span>
  </a>

  <a class="gv-store" href={GOOGLE_PLAY} target="_blank" rel="noopener" aria-label="OnePeek bei Google Play laden">
    <svg class="gv-store-ico" viewBox="0 0 512 512" width="20" height="20" aria-hidden="true">
      <path fill="#00D2FF" d="M48.9 23.2C43.2 26.6 39.8 32.8 39.8 40.9v430.2c0 8.1 3.4 14.3 9.1 17.7l1.9 1.1 240.9-240.9v-5.7L50.8 22.1l-1.9 1.1z"/>
      <path fill="#00F076" d="M89.5 4.5 48.9 23.2l241.8 241.8 82.4-82.4L89.5 4.5z"/>
      <path fill="#FFCE00" d="M372.3 329.2 291.7 265.1v-6.2l80.7-64.1 96.2 54.7c27.5 15.6 27.5 41.1 0 56.7l-96.3 54.7-.1-.1z"/>
      <path fill="#FF3B44" d="M372.4 328.6 290.7 262 48.9 488.8c9.1 9.6 24 10.8 40.9 1.3l282.6-161.5z"/>
    </svg>
    <span>Google Play</span>
  </a>
</div>

<style>
  .gv-stores { display: flex; gap: 12px; flex-wrap: wrap; }
  .gv-store-ico { flex: none; }
</style>
