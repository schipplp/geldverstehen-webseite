---
// Bettet Brevos gehostetes Anmeldeformular als iframe ein (die serve-URL
// rendert bei GET Brevos vollständiges, funktionsfähiges Formular). Das ist der
// robusteste Weg ohne eigenen Server: Absenden, Validierung und Double-Opt-in
// laufen komplett in Brevos eigener Seite — kein CORS, kein Markup-Risiko,
// mehrere Instanzen pro Seite möglich.
//
// Hinweis: Innerhalb des iframes gilt Brevos eigenes Styling. Über Aussehen
// des Formulars entscheidet die Gestaltung im Brevo-Formular-Editor.
import { BREVO_CONFIG } from '../lib/brevo.js';

export interface Props {
  /** Höhe des iframes in px (je nach Formularinhalt anpassen) */
  height?: number;
  anchorId?: string;
}
const { height = 500, anchorId } = Astro.props;
---
<div class="gv-brevo-embed" id={anchorId}>
  <iframe
    src={BREVO_CONFIG.formUrl}
    title="Anmeldeformular"
    loading="lazy"
    scrolling="auto"
    style={`display:block; width:100%; max-width:540px; height:${height}px; border:0; margin:0 auto; background:#fff; border-radius:14px;`}
  ></iframe>
</div>

<style>
  .gv-brevo-embed { width: 100%; }
</style>
