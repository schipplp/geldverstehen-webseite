---
// Blauer Footer mit Wordmark, Tagline und drei Link-Spalten.
import { u } from '../lib/url';
import { GA_MEASUREMENT_ID } from '../lib/analytics';
---
<footer class="gv-site-ft">
  <div class="gv-ft-inner">
    <div class="gv-ft-top">
      <div class="gv-ft-brand">
        <a class="gv-ft-word" href={u('/')} aria-label="GELD VERSTEHEN — Startseite"><span class="gv-ft-w1">GELD</span><span class="gv-ft-w2">VERSTEHEN</span></a>
        <p class="gv-ft-tag">Deine Finanzen im Griff. Für immer!</p>
        <div class="gv-ft-social">
          <a href="https://www.instagram.com/geldverstehen.de" target="_blank" rel="noopener" aria-label="GELD VERSTEHEN auf Instagram">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.38C1.35 2.68.94 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.38.66-.67 1.07-1.34 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.31-.79-.72-1.46-1.38-2.13-.67-.66-1.34-1.07-2.13-1.38-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0z"/><path d="M12 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 4-4 4 4 0 0 1-4 4z"/><circle cx="18.41" cy="5.59" r="1.44"/></svg>
          </a>
          <a href="https://www.youtube.com/@geld.verstehen" target="_blank" rel="noopener" aria-label="GELD VERSTEHEN auf YouTube">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.51A3.02 3.02 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3.02 3.02 0 0 0 2.12 2.14C4.5 20.45 12 20.45 12 20.45s7.5 0 9.38-.51a3.02 3.02 0 0 0 2.12-2.14A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.55 15.57V8.43L15.82 12z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@geld.verstehen" target="_blank" rel="noopener" aria-label="GELD VERSTEHEN auf TikTok">
            <svg viewBox="0 0 24 24" width="21" height="21" fill="currentColor" aria-hidden="true"><path d="M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 0 1-2.59 2.5 2.59 2.59 0 0 1-2.59-2.59 2.59 2.59 0 0 1 3.4-2.46V9.7a5.66 5.66 0 0 0-.81-.06A5.68 5.68 0 0 0 4.2 15.3a5.68 5.68 0 0 0 5.66 5.7 5.68 5.68 0 0 0 5.68-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3a4.28 4.28 0 0 1-3.24-1.48z"/></svg>
          </a>
        </div>
      </div>
      <div class="gv-ft-cols">
        <div>
          <div class="gv-ft-head">WEGE</div>
          <ul class="gv-ft-list">
            <li><a class="gv-ft-a" href={u('/podcast')}>Podcast</a></li>
            <li><a class="gv-ft-a" href={u('/app')}>App</a></li>
            <li><a class="gv-ft-a" href={u('/buch')}>Buch</a></li>
            <li><a class="gv-ft-a" href={u('/crashkurs')}>Crashkurs</a></li>
          </ul>
        </div>
        <div>
          <div class="gv-ft-head">MEHR</div>
          <ul class="gv-ft-list">
            <li><a class="gv-ft-a" href={u('/ueber')}>Über Per</a></li>
            <li><a class="gv-ft-a" href="mailto:mail@geldverstehen.de">Kontakt</a></li>
          </ul>
        </div>
        <div>
          <div class="gv-ft-head">RECHTLICHES</div>
          <ul class="gv-ft-list">
            <li><a class="gv-ft-a" href={u('/impressum')}>Impressum</a></li>
            <li><a class="gv-ft-a" href={u('/datenschutz')}>Datenschutz</a></li>
            {GA_MEASUREMENT_ID ? (
              <li><button class="gv-ft-a gv-ft-consent" type="button" data-gv-consent-open>Cookie-Einstellungen</button></li>
            ) : null}
          </ul>
        </div>
      </div>
    </div>
    <div class="gv-ft-copy">© 2026 GELD VERSTEHEN · Per Schippl</div>
  </div>
</footer>

<style>
  .gv-site-ft { background: var(--gv-blue); color: #fff; font-family: var(--font-body); padding: 56px 40px 30px; border-top: 1px solid rgba(255,255,255,.14); }
  .gv-ft-inner { max-width: 1120px; margin: 0 auto; }
  .gv-ft-top { display: flex; justify-content: space-between; gap: 48px; flex-wrap: wrap; padding-bottom: 34px; border-bottom: 1px solid rgba(255,255,255,.14); }
  .gv-ft-brand { max-width: 320px; }
  .gv-ft-word { text-decoration: none; font-family: var(--font-display); font-size: 30px; line-height: 1; letter-spacing: .5px; }
  .gv-ft-w1 { color: #fff; }
  .gv-ft-w2 { color: var(--gv-yellow); }
  .gv-ft-tag { margin-top: 14px; color: rgba(255,255,255,.62); font-size: 15px; line-height: 1.55; }
  .gv-ft-social { display: flex; gap: 14px; margin-top: 18px; }
  .gv-ft-social a { display: inline-flex; color: rgba(255,255,255,.72); transition: color .15s ease; }
  .gv-ft-social a:hover { color: #fff; }
  .gv-ft-cols { display: flex; gap: 56px; flex-wrap: wrap; }
  .gv-ft-head { font-family: var(--font-display); font-size: 15px; letter-spacing: .1em; color: rgba(255,255,255,.5); margin-bottom: 14px; }
  .gv-ft-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 11px; }
  .gv-ft-a { color: rgba(255,255,255,.72); text-decoration: none; font-size: 15px; }
  .gv-ft-a:hover { color: #fff; }
  .gv-ft-consent { background: none; border: 0; padding: 0; font-family: var(--font-body); cursor: pointer; text-align: left; }
  .gv-ft-copy { margin-top: 22px; color: rgba(255,255,255,.45); font-size: 13px; }
  @media (max-width: 860px) { .gv-site-ft { padding: 44px 22px 26px; } }
</style>
