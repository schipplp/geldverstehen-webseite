---
import Base from '../layouts/Base.astro';
import EmailOptIn from '../components/EmailOptIn.astro';
import { u } from '../lib/url';
import { img } from '../lib/images';
import '@fontsource/playfair-display/600.css'; // „Bekannt aus"-Band
---
<Base
  title="Deine Finanzen im Griff. Für immer!"
  description="GELD VERSTEHEN von Per Schippl: von Chaos in den Finanzen zu Klarheit, Struktur und einem entspannten Umgang mit deinem Geld — Podcast, App OnePeek und Buch."
  active=""
>
  <div id="top">

    <!-- ============ HERO ============ -->
    <div style="background:var(--gv-blue);">
      <div class="gv-wrap" style="padding-top:40px;">
        <div class="gv-grid-hero" style="display:grid; grid-template-columns:1.08fr .92fr; gap:44px; align-items:stretch;">

          <div style="padding-bottom:76px; padding-top:32px;">
            <h1 style="font-family:var(--font-display); font-weight:400; line-height:.98; letter-spacing:.01em; color:#fff; margin:0; padding-bottom:0.32em; font-size:clamp(52px,6vw,92px);">Deine Finanzen<br>im Griff. <span style="color:var(--gv-yellow);">Für immer!</span></h1>
            <p style="font-size:19px; line-height:1.65; color:#EAF2FA; max-width:500px; margin:8px 0 0;">Hier lernst du, wie du Struktur und Ordnung in deine Finanzen bringst — ohne Verzicht, ohne strenge Regeln. Denn es geht nicht darum, weniger zu leben. Es geht darum, dein Geld zu verstehen.</p>

            <div style="max-width:460px; margin-top:30px;">
              <div style="font-family:var(--font-display); font-size:14px; letter-spacing:.14em; color:rgba(255,255,255,.6); margin-bottom:12px;">KOSTENLOSER CRASHKURS PER MAIL</div>
              <EmailOptIn source="crashkurs" cta="Jetzt kostenlos eintragen" theme="on-blue" />
            </div>
          </div>

          <div class="gv-hero-portrait" style="position:relative; overflow:hidden; min-height:480px;">
            <img class="gv-hero-img" src={img.perHero} alt="Per Schippl, Gründer von GELD VERSTEHEN, lächelnd" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 18%; display:block; transform:scaleX(-1);" />
          </div>

        </div>
      </div>
    </div>

    <!-- ============ BEKANNT AUS ============ -->
    <div style="border-bottom:1px solid var(--gv-border); background:#fff;">
      <div class="gv-wrap" style="padding-top:36px; padding-bottom:36px; display:flex; flex-direction:column; align-items:center; gap:24px;">
        <div style="font-family:var(--font-display); font-size:13px; letter-spacing:.2em; color:var(--gv-muted);">BEKANNT AUS</div>
        <div class="gv-press">
          <span>Handelsblatt</span>
          <span>Kölner Stadt-Anzeiger</span>
          <span>Augsburger Allgemeine</span>
          <span>NWZ</span>
          <span>Express</span>
          <span>stern TV</span>
        </div>
      </div>
    </div>

    <!-- ============ WORUM ES GEHT ============ -->
    <section id="worum" class="gv-sec" style="background:#fff;">
      <div class="gv-wrap">
        <div class="gv-worum">
          <p class="gv-eyebrow"><span class="gv-rule"></span>WORUM ES HIER GEHT</p>
          <h2 class="gv-h2" style="max-width:760px;">Am Ende des Geldes ist noch so viel Monat übrig.</h2>
          <div class="gv-worum-grid">
            <div class="gv-worum-text">
              <p class="gv-lead" style="margin-top:0;">Du verdienst eigentlich ganz gut – und trotzdem fährt der Kontostand Achterbahn. Am Monatsende bleibt weniger übrig, als du dachtest. Das Thema Finanzen fühlt sich schwer an, und im Hinterkopf sitzt dieses leise Dauerrauschen: <em>Ich müsste mich mal drum kümmern.</em></p>
              <p class="gv-lead">Genau dieses Gefühl begegnet mir in meinen Coachings immer wieder. Und ich weiß: Es liegt nicht daran, dass du zu wenig verdienst oder dir die Disziplin fehlt.</p>
              <p class="gv-lead">Genau da setzt GELD VERSTEHEN an: Sobald du die einfachen Prinzipien hinter deinem Geld verstehst, kommt die Ordnung fast von allein. Und mit ihr die Ruhe. Ganz ohne Sparen um jeden Preis – und ohne jeden Kaffee dreimal umzudrehen.</p>
              <p class="gv-lead"><strong>Der Weg dahin ist leichter, als du denkst – und du musst ihn nicht allein gehen.</strong></p>
            </div>
            <aside class="gv-worum-quote">
              <span class="gv-worum-qmark" aria-hidden="true">„</span>
              <p>Jeder Normalverdiener kann 10, 20 oder sogar 30 % zur Seite legen – ohne sich spürbar einzuschränken.</p>
            </aside>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ ÜBER PER ============ -->
    <section id="ueber" class="gv-sec" style="background:#fff; border-top:1px solid var(--gv-border);">
      <div class="gv-wrap">
        <div class="gv-split" style="display:grid; grid-template-columns:.85fr 1.15fr; gap:56px; align-items:center;">
          <div class="gv-split-media">
            <img class="gv-ueber-img" src={img.perUeberSplit} alt="Per Schippl im Porträt" style="width:100%; height:480px; object-fit:cover; border-radius:14px; display:block;" />
          </div>
          <div>
            <p class="gv-eyebrow"><span class="gv-rule"></span>ÜBER PER</p>
            <h2 class="gv-h2">Hi, ich bin Per.</h2>
            <p style="font-size:18px; line-height:1.75; color:var(--gv-ink-soft); margin:20px 0 14px;">Struktur und Ordnung waren für mich schon immer wichtig — und Geld hat mich schon immer fasziniert. 2016 habe ich <strong>geldverstehen.de</strong> gestartet, um das weiterzugeben, was für mich intuitiv funktioniert: einen Umgang mit Geld, der auf Verstehen basiert statt auf Verzicht.</p>
            <p style="font-size:18px; line-height:1.75; color:var(--gv-ink-soft); margin:0;">Daraus sind über die Jahre ein Buch, ein Podcast und meine App OnePeek geworden. Der Kern ist immer derselbe geblieben: <strong>Wer chaotische Finanzen hat, dem fehlt keine Disziplin — dem fehlt ein System, das zu seinem Leben passt.</strong> Genau das findest du hier.</p>
            <div style="margin-top:30px;"><a class="gv-btn-ghost-b" href={u('/ueber')}>Mehr über mich</a></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DREI WEGE (Tiles) ============ -->
    <section id="wege" class="gv-sec" style="background:#fff; border-top:1px solid var(--gv-border);">
      <div class="gv-wrap">
        <div style="max-width:760px; margin-bottom:44px;">
          <p class="gv-eyebrow"><span class="gv-rule"></span>DEINE WEGE</p>
          <h2 class="gv-h2">Drei Wege, dein Geld zu verstehen.</h2>
        </div>
        <div class="gv-3tiles">

          <a class="gv-tile" href={u('/app')}>
            <div class="gv-tile-media"><img src={img.onepeekApp} alt="Screenshot der OnePeek App mit Finanzübersicht" style="max-width:100%; max-height:100%; object-fit:contain;" /></div>
            <div class="gv-tile-body">
              <div class="gv-tile-label"><span style="color:var(--gv-blue);">01</span>&nbsp;&nbsp;APP</div>
              <h3 class="gv-tile-title">Die Haushaltsbuch-App OnePeek</h3>
              <p class="gv-tile-text">Einnahmen, Ausgaben und Ziele auf einen Blick — ohne Excel-Wüste.</p>
              <span class="gv-mehr">Mehr erfahren &rarr;</span>
            </div>
          </a>

          <a class="gv-tile" href={u('/buch')}>
            <div class="gv-tile-media"><img src={img.buchCover} alt="Cover des GELD VERSTEHEN Buchs" style="max-width:100%; max-height:100%; object-fit:contain; border-radius:10px; box-shadow:0 12px 30px rgba(15,35,58,.14);" /></div>
            <div class="gv-tile-body">
              <div class="gv-tile-label"><span style="color:var(--gv-blue);">02</span>&nbsp;&nbsp;BUCH</div>
              <h3 class="gv-tile-title">GELD VERSTEHEN – Das Buch</h3>
              <p class="gv-tile-text">Der komplette Ansatz zum Nachlesen. Erscheint bald in Neuauflage.</p>
              <span class="gv-mehr">Mehr erfahren &rarr;</span>
            </div>
          </a>

          <a class="gv-tile" href={u('/podcast')}>
            <div class="gv-tile-media"><img src={img.podcastCover} alt="Cover des GELD VERSTEHEN Podcasts" style="max-width:100%; max-height:100%; object-fit:contain; border-radius:10px; box-shadow:0 12px 30px rgba(15,35,58,.14);" /></div>
            <div class="gv-tile-body">
              <div class="gv-tile-label"><span style="color:var(--gv-blue);">03</span>&nbsp;&nbsp;PODCAST</div>
              <h3 class="gv-tile-title">GELD VERSTEHEN – Der Podcast</h3>
              <p class="gv-tile-text">Kurze Folgen, ein klarer Impuls — im Alltag sofort spürbar. Jede Woche neu.</p>
              <span class="gv-mehr">Mehr erfahren &rarr;</span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- ============ CLOSING BAND (Newsletter) ============ -->
    <section class="gv-sec" style="background:var(--gv-blue); padding-top:80px; padding-bottom:80px;">
      <div class="gv-wrap" style="text-align:center;">
        <p style="font-family:var(--font-display); font-weight:400; font-size:clamp(28px,3.4vw,44px); line-height:1.04; color:#fff; margin:0 auto; max-width:820px;">Interesse an effektiven Strategien, dein Geld besser <span style="color:var(--gv-yellow);">zusammenzuhalten?</span></p>
        <p style="font-size:18px; line-height:1.6; color:#EAF2FA; margin:16px auto 30px; max-width:560px;">Dann starte jetzt mit unserem kostenlosen E-Mail-Kurs und wir zeigen dir Schritt für Schritt, wie du langfristig dein Geld immer besser zusammenhalten kannst:</p>
        <div style="max-width:460px; margin:0 auto; text-align:left;">
          <EmailOptIn source="crashkurs" cta="Jetzt kostenlos eintragen" theme="on-blue" successText="Bitte bestätige deine Anmeldung in deiner E-Mail." />
        </div>
      </div>
    </section>

  </div>
</Base>

<style>
  .gv-press { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 16px 40px; }
  .gv-press span { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; font-size: 21px; color: #7c8794; }

  /* „Worum es geht" — Text + hervorgehobenes Zitat als visueller Anker */
  .gv-worum { max-width: 1000px; }
  .gv-worum-grid { display: grid; grid-template-columns: 1.45fr .85fr; gap: 44px; align-items: center; margin-top: 20px; }
  .gv-worum-text .gv-lead { margin: 0 0 16px; }
  .gv-worum-text .gv-lead:last-child { margin-bottom: 0; }
  .gv-worum-quote { position: relative; background: var(--gv-blue); color: #fff; border-radius: 18px; padding: 30px 30px 34px; box-shadow: var(--shadow-md); }
  .gv-worum-qmark { display: block; font-family: var(--font-display); font-size: 72px; line-height: .5; color: var(--gv-yellow); margin-bottom: 6px; }
  .gv-worum-quote p { margin: 0; font-family: var(--font-display); font-weight: 400; letter-spacing: .01em; font-size: clamp(30px, 3.2vw, 40px); line-height: 1.04; }
  @media (max-width: 860px) {
    .gv-worum-grid { grid-template-columns: 1fr; gap: 28px; }
  }

  .gv-3tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .gv-tile { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--gv-border); border-radius: 16px; overflow: hidden; text-decoration: none; transition: transform .18s ease, box-shadow .18s ease; }
  .gv-tile:hover { transform: translateY(-4px); box-shadow: 0 18px 44px rgba(15,35,58,.14); }
  .gv-tile-media { height: 210px; background: var(--gv-surface); display: flex; align-items: center; justify-content: center; padding: 22px; }
  .gv-tile-body { padding: 24px 26px 28px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .gv-tile-label { font-family: var(--font-display); font-size: 14px; letter-spacing: .14em; color: var(--gv-muted); }
  .gv-tile-title { font-family: var(--font-display); font-weight: 400; font-size: 26px; color: var(--gv-ink); margin: 0; }
  .gv-tile-text { font-size: 15px; line-height: 1.6; color: var(--gv-ink-soft); margin: 0; flex: 1; }
  .gv-mehr { margin-top: 12px; font-family: var(--font-body); font-weight: 700; font-size: 15px; color: var(--gv-blue); }
  .gv-tile:hover .gv-mehr { text-decoration: underline; }

  @media (max-width: 860px) {
    .gv-grid-hero { grid-template-columns: 1fr !important; }
    /* Mobil: nur Slogan + Formular, Porträt ausblenden */
    .gv-hero-portrait { display: none !important; }
    .gv-split { grid-template-columns: 1fr !important; gap: 32px !important; }
    .gv-3tiles { grid-template-columns: 1fr !important; }
    .gv-ueber-img { height: 320px !important; }
  }
</style>

<script>
  // Reveal-on-scroll: Sektionen unterhalb des Folds faden ein.
  const root = document.getElementById('top');
  if (root && 'IntersectionObserver' in window) {
    const vh = window.innerHeight || 800;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('gv-in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    root.querySelectorAll('section').forEach((t) => {
      if (t.getBoundingClientRect().top > vh * 0.85) { t.classList.add('gv-rv'); io.observe(t); }
    });
  }
</script>
