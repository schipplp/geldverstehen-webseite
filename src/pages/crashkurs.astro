---
import Base from '../layouts/Base.astro';
import BrevoEmbed from '../components/BrevoEmbed.astro';
import { u } from '../lib/url';
import { img } from '../lib/images';
---
<Base
  title="Kostenloser Crashkurs — Vom Geld-Chaos zur Klarheit"
  description="Der kostenlose GELD VERSTEHEN Crashkurs per E-Mail: die wichtigsten Schritte zu mehr Überblick, Tag für Tag verständlich erklärt. Ein paar Minuten täglich genügen."
  active=""
>
  <!-- HERO mit Opt-in -->
  <div style="background:var(--gv-blue);">
    <div class="gv-wrap" style="padding-top:56px; padding-bottom:64px;">
      <div class="gv-split" style="display:grid; grid-template-columns:1.08fr .92fr; gap:52px; align-items:center;">
        <div>
          <div style="font-family:var(--font-display); font-size:17px; letter-spacing:.12em; color:var(--gv-yellow); margin-bottom:16px;">KOSTENLOSER CRASHKURS</div>
          <h1 style="font-family:var(--font-display); font-weight:400; line-height:1.0; letter-spacing:.01em; color:#fff; margin:0; font-size:clamp(44px,5.4vw,76px);">Vom Geld-Chaos zur <span style="color:var(--gv-yellow);">Klarheit</span> — in wenigen Tagen.</h1>
          <p style="font-size:19px; line-height:1.6; color:#EAF2FA; max-width:480px; margin:22px 0 26px;">Die wichtigsten Schritte zu mehr Überblick — gratis per E-Mail, Tag für Tag verständlich erklärt. Ein paar Minuten täglich genügen.</p>
          <div style="max-width:440px;">
            <BrevoEmbed anchorId="crashkurs-form" />
          </div>
        </div>
        <img src={img.perCrashkurs} alt="Per Schippl im Porträt" style="width:100%; height:460px; object-fit:cover; border-radius:18px; display:block; box-shadow:0 24px 60px rgba(0,0,0,.3);" />
      </div>
    </div>
  </div>

  <!-- WHAT'S INSIDE -->
  <section style="background:#fff;">
    <div class="gv-wrap" style="padding-top:84px; padding-bottom:84px;">
      <div class="gv-bar"></div>
      <p class="gv-eyebrow-plain" style="color:var(--gv-blue); margin:16px 0 8px;">WAS DICH ERWARTET</p>
      <h2 class="gv-h2" style="max-width:760px;">Dein Weg in vier kurzen Lektionen</h2>
      <div style="display:grid; gap:18px; margin-top:44px; max-width:860px;">
        <div class="gv-lesson">
          <div class="gv-lesson-day">Tag 1</div>
          <div><h3 class="gv-lesson-h">Der ehrliche Kassensturz</h3><p class="gv-lesson-p">Wo stehst du wirklich? In 20 Minuten zum ersten klaren Überblick.</p></div>
        </div>
        <div class="gv-lesson">
          <div class="gv-lesson-day">Tag 2</div>
          <div><h3 class="gv-lesson-h">Fixkosten entlarven</h3><p class="gv-lesson-p">Welche Kosten dich jeden Monat unbemerkt Geld kosten — und was du tust.</p></div>
        </div>
        <div class="gv-lesson">
          <div class="gv-lesson-day">Tag 3</div>
          <div><h3 class="gv-lesson-h">Dein einfaches System</h3><p class="gv-lesson-p">Ein Aufteilungs-System, das zu dir passt — ohne Verzicht-Marathon.</p></div>
        </div>
        <div class="gv-lesson">
          <div class="gv-lesson-day">Tag 4</div>
          <div><h3 class="gv-lesson-h">Dranbleiben leicht gemacht</h3><p class="gv-lesson-p">Wie du dein neues System mit Podcast und App locker beibehältst.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section style="background:var(--gv-surface);">
    <div class="gv-wrap" style="padding-top:72px; padding-bottom:72px;">
      <h2 class="gv-h2" style="text-align:center; margin-bottom:36px;">Was Teilnehmer:innen sagen</h2>
      <div class="gv-2" style="display:grid; grid-template-columns:1fr 1fr; gap:24px; align-items:start;">
        <div class="gv-quote">
          <div class="gv-stars">★★★★★</div>
          <p class="gv-quote-p">„Hallo und einen schönen guten Morgen Herr Schippl, vielen Dank für Ihre grundlegenden Überlegungen im Paket ‚Geld verstehen'. Mir helfen Ihre Ansätze jetzt schon (nach nur einer knappen Woche) weiter."</p>
          <div class="gv-quote-who">— Robert</div>
        </div>
        <div class="gv-quote">
          <div class="gv-stars">★★★★★</div>
          <p class="gv-quote-p">„Das dumpfe Gefühl, keinen Überblick zu haben ist weg. Es läuft."</p>
          <div class="gv-quote-who">— Edeltraud</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL OPT-IN -->
  <section style="background:var(--gv-blue);">
    <div class="gv-wrap" style="padding-top:80px; padding-bottom:80px;">
      <div style="max-width:560px; margin:0 auto; text-align:center;">
        <h2 style="font-family:var(--font-display); font-weight:400; font-size:clamp(38px,4.6vw,56px); line-height:1; color:#fff; margin:0 0 14px;">Starte heute. Kostenlos.</h2>
        <p style="font-size:18px; line-height:1.6; color:#EAF2FA; margin:0 0 26px;">Trag dich ein und erhalte die erste Lektion sofort per E-Mail.</p>
        <div>
          <a class="gv-btn" href="#crashkurs-form">Jetzt kostenlos eintragen</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .gv-lesson { display: flex; gap: 22px; align-items: flex-start; background: var(--gv-surface); border: 1px solid var(--gv-border); border-radius: 16px; padding: 26px; }
  .gv-lesson-day { font-family: var(--font-display); font-size: 34px; line-height: 1; color: var(--gv-yellow); min-width: 64px; }
  .gv-lesson-h { font-family: var(--font-display); font-weight: 400; font-size: 24px; color: var(--gv-ink); margin: 0 0 6px; }
  .gv-lesson-p { font-size: 15px; line-height: 1.6; color: var(--gv-ink-soft); margin: 0; }

  .gv-quote { background: #fff; border: 1px solid var(--gv-border); border-radius: 16px; padding: 26px; }
  .gv-stars { color: var(--gv-yellow); font-size: 16px; margin-bottom: 10px; }
  .gv-quote-p { font-size: 16px; line-height: 1.6; color: var(--gv-ink); margin: 0 0 14px; }
  .gv-quote-who { font-size: 14px; color: var(--gv-muted); }

  @media (max-width: 860px) {
    .gv-split { grid-template-columns: 1fr !important; gap: 30px !important; }
    .gv-2 { grid-template-columns: 1fr !important; }
  }
</style>
