---
import Base from '../layouts/Base.astro';
import { u } from '../lib/url';
import { img } from '../lib/images';

// Folgendaten stammen aus dem Designpaket (letscast.fm-Host des Podcasts).
const episodes = [
  { no: '#74', title: 'Warum Geld in Beziehungen so oft für Streit sorgt – und wie ihr das löst', dur: '11 Min', date: '9. Juli 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/e0cf9878.mp3', link: 'https://geldverstehen.letscast.fm/episode/warum-geld-in-beziehungen-so-oft-fuer-streit-sorgt-und-wie-ihr-das-loest' },
  { no: '#73', title: '5 Finanzregeln, die du nie brechen solltest', dur: '12 Min', date: '2. Juli 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/741915e4.mp3', link: 'https://geldverstehen.letscast.fm/episode/5-finanzregeln-die-du-nie-brechen-solltest' },
  { no: '#72', title: 'Warum ich keine Budgetplanung empfehle', dur: '8 Min', date: '25. Juni 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/b57e030b.mp3', link: 'https://geldverstehen.letscast.fm/episode/warum-ich-keine-budgetplanung-empfehle' },
  { no: '#71', title: 'Was finanziell erfolgreiche Menschen anders machen', dur: '9 Min', date: '18. Juni 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/8d3113f0.mp3', link: 'https://geldverstehen.letscast.fm/episode/was-finanziell-erfolgreiche-menschen-anders-machen-3-kleine-stellschrauben' },
  { no: '#70', title: 'Du machst vieles richtig – und gibst trotzdem immer wieder auf?', dur: '9 Min', date: '11. Juni 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/2cfa6c19.mp3', link: 'https://geldverstehen.letscast.fm/episode/du-machst-vieles-richtig-und-gibst-trotzdem-immer-wieder-auf' },
  { no: '#69', title: 'Du kennst deine Geldfresser – und änderst trotzdem nichts. Warum?', dur: '6 Min', date: '4. Juni 2026', mp3: 'https://lcdn.letscast.fm/media/podcast/4d31713a/episode/d546b58f.mp3', link: 'https://geldverstehen.letscast.fm/episode/du-kennst-deine-geldfresser-und-aenderst-trotzdem-nichts-warum' },
];
const current = episodes[0];
const allEpisodes = 'https://geldverstehen.letscast.fm';
---
<Base
  title="Der Podcast — Jede Woche ein Stück mehr Klarheit"
  description="Der GELD VERSTEHEN Podcast: konkrete Impulse und praktische Tipps rund um Geld — kurze Folgen zum Mitnehmen, jede Woche neu."
  active="podcast"
>
  <!-- HERO -->
  <div style="background:var(--gv-blue);">
    <div class="gv-wrap" style="padding-top:56px; padding-bottom:64px;">
      <div class="gv-split" style="display:grid; grid-template-columns:1.02fr .98fr; gap:52px; align-items:center;">
        <div>
          <div style="font-family:var(--font-display); font-size:17px; letter-spacing:.12em; color:var(--gv-yellow); margin-bottom:16px;">DER PODCAST</div>
          <h1 style="font-family:var(--font-display); font-weight:400; line-height:1.0; letter-spacing:.01em; color:#fff; margin:0; font-size:clamp(44px,5.4vw,78px);">Jede Woche ein Stück mehr <span style="color:var(--gv-yellow);">Klarheit</span>.</h1>
          <p style="font-size:19px; line-height:1.6; color:#EAF2FA; max-width:480px; margin:22px 0 28px;">Konkrete Impulse und praktische Tipps rund um Geld — zum Mitnehmen für unterwegs. Jede Woche eine neue Folge.</p>
          <div style="display:flex; gap:12px; flex-wrap:wrap;">
            <a class="gv-store" href="https://open.spotify.com/show/4eydcBTI1cYTk6LZndehWU" target="_blank" rel="noopener" aria-label="GELD VERSTEHEN Podcast auf Spotify">
              <svg viewBox="0 0 24 24" width="19" height="19" style="flex:none" aria-hidden="true"><path fill="#1ED760" d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.4-.7.5-1 .3-2.8-1.7-6.3-2.1-10.4-1.2-.4.1-.8-.2-.9-.6-.1-.4.2-.8.6-.9 4.5-1 8.4-.6 11.5 1.3.4.2.5.7.2 1.1zm1.5-3.3c-.3.4-.8.6-1.2.3-3.2-2-8.1-2.5-11.9-1.4-.5.2-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.4-1.3 9.8-.7 13.5 1.5.3.3.5.9.1 1.3zm.1-3.4C15.5 8.3 8.8 8.1 5 9.2c-.6.2-1.2-.2-1.4-.7-.2-.6.2-1.2.7-1.4 4.4-1.3 11.8-1.1 16.4 1.6.5.3.7 1 .4 1.5-.3.6-1 .8-1.5.5z"/></svg>
              <span>Spotify</span>
            </a>
            <a class="gv-store" href="https://podcasts.apple.com/de/podcast/geld-verstehen-struktur-und-ordnung-in-deinen-finanzen/id1798477013" target="_blank" rel="noopener" aria-label="GELD VERSTEHEN Podcast bei Apple Podcasts">
              <svg viewBox="0 0 24 24" width="19" height="19" style="flex:none" aria-hidden="true">
                <path d="M4.9 15.2a8 8 0 1 1 14.2 0" fill="none" stroke="#C24BE6" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M7.8 13.6a5 5 0 1 1 8.4 0" fill="none" stroke="#C24BE6" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="12" cy="10.2" r="2.3" fill="#C24BE6"/>
                <path d="M9.7 20.1c.25-2.4.7-3.6 2.3-3.6s2.05 1.2 2.3 3.6c.13 1.3-1 2.2-2.3 2.2s-2.43-.9-2.3-2.2z" fill="#C24BE6"/>
              </svg>
              <span>Apple Podcasts</span>
            </a>
            <a class="gv-store" href={allEpisodes} target="_blank" rel="noopener">Alle Plattformen</a>
          </div>
        </div>
        <div style="display:flex; justify-content:center;">
          <img src={img.podcastCover} alt="Cover des GELD VERSTEHEN Podcasts" style="width:100%; max-width:420px; aspect-ratio:1/1; object-fit:cover; border-radius:18px; display:block; box-shadow:0 24px 60px rgba(0,0,0,.34);" />
        </div>
      </div>
    </div>
  </div>

  <!-- TOPICS -->
  <section style="background:#fff;">
    <div class="gv-wrap" style="padding-top:84px; padding-bottom:40px;">
      <div class="gv-bar"></div>
      <p class="gv-eyebrow-plain" style="color:var(--gv-blue); margin:16px 0 8px;">WORUM ES GEHT</p>
      <h2 class="gv-h2" style="max-width:760px;">Themen, die wirklich etwas verändern</h2>
      <div class="gv-3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:44px;">
        <div class="gv-topic">
          <h3 class="gv-topic-h">Der erste Überblick</h3>
          <p class="gv-topic-p">Wo dein Geld wirklich hingeht — und wie du in den Griff bekommst, was dir wichtig ist.</p>
        </div>
        <div class="gv-topic">
          <h3 class="gv-topic-h">Sparen ohne Verzicht</h3>
          <p class="gv-topic-p">Systeme, die im Alltag funktionieren — statt strenger Regeln, die niemand durchhält.</p>
        </div>
        <div class="gv-topic">
          <h3 class="gv-topic-h">Ruhe statt Geldstress</h3>
          <p class="gv-topic-p">Warum Geld oft mehr mit Kopf und Gewohnheiten zu tun hat als mit Zahlen — und wie du gelassener wirst.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EPISODES -->
  <section style="background:#fff;">
    <div class="gv-wrap" style="padding-top:56px; padding-bottom:84px;">
      <h2 class="gv-h2" style="margin-bottom:8px;">Neueste Folgen</h2>
      <p style="font-size:16px; color:var(--gv-muted); margin:6px 0 28px;">Direkt hier reinhören &mdash; jede Woche eine neue Folge.</p>

      <!-- PLAYER -->
      <div id="gv-player" style="display:flex; align-items:center; gap:20px; background:var(--gv-surface); border:1px solid var(--gv-border); border-radius:16px; padding:20px 24px; margin-bottom:20px; flex-wrap:wrap;">
        <img src={img.podcastCover} alt="" style="width:74px; height:74px; border-radius:10px; object-fit:cover; flex-shrink:0;" />
        <div style="flex:1; min-width:220px;">
          <div id="gv-player-no" style="font-family:var(--font-display); font-size:15px; letter-spacing:.08em; color:var(--gv-blue);">{current.no} &middot; JETZT SPIELEN</div>
          <div id="gv-player-title" style="font-family:var(--font-body); font-weight:700; font-size:17px; color:var(--gv-ink); line-height:1.3; margin-top:2px;">{current.title}</div>
        </div>
        <audio id="gv-player-audio" controls src={current.mp3} style="height:44px; width:100%; max-width:340px;"></audio>
      </div>

      <div>
        {episodes.map((ep) => (
          <div class="gv-ep" data-no={ep.no} data-title={ep.title} data-mp3={ep.mp3} role="button" tabindex="0">
            <div class="gv-ep-no">{ep.no}</div>
            <div style="flex:1;">
              <div class="gv-ep-title">{ep.title}</div>
              <div class="gv-ep-meta">{ep.dur} &middot; {ep.date}</div>
            </div>
            <a class="gv-btn" href={ep.link} target="_blank" rel="noopener" style="white-space:nowrap;">Details</a>
          </div>
        ))}
      </div>

      <div style="margin-top:32px;">
        <a href={allEpisodes} target="_blank" rel="noopener" style="font-family:var(--font-body); font-weight:700; font-size:16px; color:var(--gv-blue); text-decoration:none;">Alle Folgen ansehen &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--gv-blue);">
    <div class="gv-wrap" style="padding-top:80px; padding-bottom:80px; text-align:center;">
      <h2 style="font-family:var(--font-display); font-weight:400; font-size:clamp(38px,4.6vw,56px); line-height:1; color:#fff; margin:0 0 14px;">Keine Folge mehr verpassen</h2>
      <p style="font-size:18px; line-height:1.6; color:#EAF2FA; margin:0 auto 28px; max-width:460px;">Abonniere den Podcast auf deiner Lieblingsplattform und verpasse keine neue Folge mehr.</p>
      <a class="gv-btn" href={allEpisodes} target="_blank" rel="noopener">Jetzt abonnieren</a>
    </div>
  </section>
</Base>

<style>
  .gv-topic { background: var(--gv-surface); border: 1px solid var(--gv-border); border-radius: 16px; padding: 28px; }
  .gv-topic-h { font-family: var(--font-display); font-weight: 400; font-size: 24px; color: var(--gv-ink); margin: 0 0 8px; }
  .gv-topic-p { font-size: 15px; line-height: 1.6; color: var(--gv-ink-soft); margin: 0; }

  .gv-ep { display: flex; align-items: center; gap: 22px; padding: 22px 0; border-bottom: 1px solid var(--gv-border); cursor: pointer; }
  .gv-ep:focus-visible { outline: 2px solid var(--gv-blue); outline-offset: 4px; border-radius: 8px; }
  .gv-ep-no { font-family: var(--font-display); font-size: 40px; line-height: 1; color: var(--gv-blue); min-width: 74px; }
  .gv-ep-title { font-family: var(--font-display); font-size: 24px; color: var(--gv-ink); line-height: 1.1; }
  .gv-ep-meta { font-size: 14px; color: var(--gv-muted); margin-top: 4px; }

  @media (max-width: 860px) {
    .gv-split { grid-template-columns: 1fr !important; gap: 32px !important; }
    .gv-3 { grid-template-columns: 1fr !important; }
    .gv-ep { flex-wrap: wrap; gap: 10px 18px; }
  }
</style>

<script>
  const audio = document.getElementById('gv-player-audio') as HTMLAudioElement | null;
  const noEl = document.getElementById('gv-player-no');
  const titleEl = document.getElementById('gv-player-title');

  function selectEpisode(el: HTMLElement) {
    if (!audio || !noEl || !titleEl) return;
    const mp3 = el.dataset.mp3;
    const no = el.dataset.no || '';
    const title = el.dataset.title || '';
    if (!mp3) return;
    audio.src = mp3;
    noEl.textContent = `${no} · JETZT SPIELEN`;
    titleEl.textContent = title;
    audio.play().catch(() => { /* Autoplay evtl. blockiert — kein Problem */ });
  }

  document.querySelectorAll<HTMLElement>('.gv-ep').forEach((el) => {
    el.addEventListener('click', (e) => {
      // Klick auf den „Details"-Link nicht abfangen
      if ((e.target as HTMLElement).closest('a')) return;
      selectEpisode(el);
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectEpisode(el); }
    });
  });
</script>
